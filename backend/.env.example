OTP_TTL_MINUTES=10

# Optional SMTP config (if omitted, OTP is logged in backend console)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ems.local
